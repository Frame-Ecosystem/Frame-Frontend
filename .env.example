# Required API endpoints
NEXT_PUBLIC_API_URL=https://frame-backend-apis.onrender.com
NEXT_PUBLIC_FRONTEND_URL=https://app.example.com

# Optional OAuth API override. Leave empty to use NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_GOOGLE_AUTH_BASE_URL=

# Backend auth cookie contract
# The backend AuthSystem sets this HttpOnly cookie for web sessions.
AUTH_SESSION_COOKIE_NAME=refreshToken

# Firebase Cloud Messaging
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Google integrations
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional client error reporting endpoint
NEXT_PUBLIC_ERROR_REPORTING_ENDPOINT=
